{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dakal",
  "version": "0.1.0",
  "identifier": "net.soheilroko.dakal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dakal",
        "width": 400,
        "height": 560,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "visible": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["zip"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "webviewInstallMode": "embedBootstrapper"
    }
  }
}
